# Environment variables for OctoFit Tracker Frontend

# For GitHub Codespaces, set REACT_APP_CODESPACE_NAME to your codespace name
# The app will construct the API URL as:
# https://${REACT_APP_CODESPACE_NAME}-8000.app.github.dev/api/

# For local development with Django running on localhost:8000
# Leave REACT_APP_CODESPACE_NAME unset or empty

# Example for Codespaces:
# REACT_APP_CODESPACE_NAME=my-codespace-name

# The frontend will use HTTPS protocol in Codespaces
# and HTTP protocol for localhost development
